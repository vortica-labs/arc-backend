NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:3000,https://www.squadhunt.in,https://admin.squadhunt.in
GENERAL_API_RATE_LIMIT_MAX=2000
GENERAL_API_RATE_LIMIT_WINDOW_MS=900000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/gaming-social-platform

# Redis / ElastiCache (required for Socket.IO, queues, and caching)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS=false

# JWT
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_this_with_another_long_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Sensitive data encryption (use independent, random values from AWS Secrets Manager)
# Keep BANK_DETAILS_ENCRYPTION_KEY stable; rotating it requires re-encrypting existing records.
BANK_DETAILS_ENCRYPTION_KEY=replace_with_at_least_32_random_characters
ENABLE_PAYLOAD_ENCRYPTION=false
ENCRYPTION_KEY=replace_with_at_least_32_random_characters

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google OAuth
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
CLIENT_URL=http://localhost:3000

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=replace_with_a_dedicated_webhook_secret
RAZORPAY_PREMIUM_PLAN_IDS={}
RAZORPAY_PLAN_PLAYER_PRO_MONTHLY=
RAZORPAY_PLAN_PLAYER_PRO_QUARTERLY=
RAZORPAY_PLAN_PLAYER_PRO_YEARLY=
RAZORPAY_PLAN_PLAYER_PRO_PLUS_MONTHLY=
RAZORPAY_PLAN_PLAYER_PRO_PLUS_QUARTERLY=
RAZORPAY_PLAN_PLAYER_PRO_PLUS_YEARLY=
RAZORPAY_PLAN_TEAM_PRO_MONTHLY=
RAZORPAY_PLAN_TEAM_PRO_QUARTERLY=
RAZORPAY_PLAN_TEAM_PRO_YEARLY=
RAZORPAY_PLAN_TEAM_ORG_MONTHLY=
RAZORPAY_PLAN_TEAM_ORG_QUARTERLY=
RAZORPAY_PLAN_TEAM_ORG_YEARLY=
PREMIUM_SUBSCRIPTION_YEARS=10
PREMIUM_LIFECYCLE_JOB_ENABLED=true
PREMIUM_LIFECYCLE_CRON=*/5 * * * *
PREMIUM_LIFECYCLE_BATCH_SIZE=200
PREMIUM_PROVIDER_RECONCILIATION_ENABLED=true

# Temporary structured diagnostics for server-authoritative Random Connect access checks
RANDOM_CONNECT_ENTITLEMENT_DEBUG=false
RANDOM_CONNECT_ADMISSION_LEASE_MS=60000

# AI / Gemini
GEMINI_API_KEY=your_gemini_api_key

# SMTP / Email
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=App <noreply@example.com>

# Push notifications (Expo is the gateway; FCM/APNs are downstream)
PUSH_NOTIFICATION_PROVIDER=expo
EXPO_ACCESS_TOKEN=
EXPO_PUSH_SECURITY_MODE=enabled
EXPO_PUSH_REQUEST_TIMEOUT_MS=15000
EXPO_MAX_PAYLOAD_BYTES=4096
EXPO_PUSH_TOKEN_MAX_LENGTH=512
EXPO_GENERIC_PUSH_SEND_MAX_ATTEMPTS=5
EXPO_GENERIC_PUSH_INLINE_SEND_ATTEMPTS=1
EXPO_GENERIC_PUSH_RETRY_BASE_MS=10000
EXPO_GENERIC_PUSH_RECEIPT_DELAY_MS=900000
EXPO_GENERIC_PUSH_RECEIPT_MAX_ATTEMPTS=8
EXPO_GENERIC_PUSH_RECEIPT_JOB_ATTEMPTS=6
PUSH_WORKER_CONCURRENCY=2
PUSH_DELIVERY_LOG_RETENTION_DAYS=90
PUSH_DEVICE_TOMBSTONE_DAYS=90
PUSH_REQUEST_RECOVERY_MAX_ATTEMPTS=5
NOTIFICATION_PUSH_OUTBOX_MAX_ATTEMPTS=12
CALL_RING_TTL_SECONDS=30
CALL_DISCONNECT_GRACE_MS=30000
MAX_CALL_DURATION_SECONDS=14400
CALL_STATE_PUSH_MAX_ATTEMPTS=12
INITIAL_VOIP_OUTBOX_MAX_ATTEMPTS=5

# iOS killed/locked incoming calls (direct APNs PushKit; never commit the .p8 key)
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_PRIVATE_KEY_BASE64=
APNS_BUNDLE_ID=com.arcSquadHunt
APNS_VOIP_TOPIC=com.arcSquadHunt.voip
APNS_ENVIRONMENT=production
APNS_VOIP_MAX_ATTEMPTS=5
APNS_VOIP_REQUEST_TIMEOUT_MS=10000
APNS_VOIP_CONCURRENCY=10

# Music API
JAMENDO_CLIENT_ID=your_jamendo_client_id

# ZegoCloud (Video/Voice Calls)

GOOGLE_CALLBACK_URL=https://api.squadhunt.com/api/auth/google/callback
# CLIENT_URL=https://arc.squadhunt.com

# Admin Panel Login (single hardcoded admin)
# Set ADMIN_USERNAME to the desired admin username
# Set ADMIN_PASSWORD_HASH to the bcrypt hash of your admin password
# Generate hash: node scripts/generate-admin-hash.js yourpassword
ADMIN_USERNAME=arcadmin
ADMIN_PASSWORD_HASH=
