NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:3000,https://www.squadhunt.in,https://admin.squadhunt.in

# MongoDB
MONGODB_URI=mongodb://localhost:27017/gaming-social-platform

# Redis / ElastiCache (required for Socket.IO, queues, and caching)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS=false

# JWT
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_this_with_another_long_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google OAuth
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
CLIENT_URL=http://localhost:3000

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=replace_with_a_dedicated_webhook_secret
RAZORPAY_PREMIUM_PLAN_IDS={}
RAZORPAY_PLAN_PLAYER_PRO_MONTHLY=
RAZORPAY_PLAN_PLAYER_PRO_QUARTERLY=
RAZORPAY_PLAN_PLAYER_PRO_YEARLY=
RAZORPAY_PLAN_PLAYER_PRO_PLUS_MONTHLY=
RAZORPAY_PLAN_PLAYER_PRO_PLUS_QUARTERLY=
RAZORPAY_PLAN_PLAYER_PRO_PLUS_YEARLY=
RAZORPAY_PLAN_TEAM_PRO_MONTHLY=
RAZORPAY_PLAN_TEAM_PRO_QUARTERLY=
RAZORPAY_PLAN_TEAM_PRO_YEARLY=
RAZORPAY_PLAN_TEAM_ORG_MONTHLY=
RAZORPAY_PLAN_TEAM_ORG_QUARTERLY=
RAZORPAY_PLAN_TEAM_ORG_YEARLY=
PREMIUM_SUBSCRIPTION_YEARS=10
PREMIUM_LIFECYCLE_JOB_ENABLED=true
PREMIUM_LIFECYCLE_CRON=*/5 * * * *
PREMIUM_LIFECYCLE_BATCH_SIZE=200
PREMIUM_PROVIDER_RECONCILIATION_ENABLED=true

# AI / Gemini
GEMINI_API_KEY=your_gemini_api_key

# SMTP / Email
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=App <noreply@example.com>

# Music API
JAMENDO_CLIENT_ID=your_jamendo_client_id

# ZegoCloud (Video/Voice Calls)

GOOGLE_CALLBACK_URL=https://api.squadhunt.com/api/auth/google/callback
# CLIENT_URL=https://arc.squadhunt.com

# Admin Panel Login (single hardcoded admin)
# Set ADMIN_USERNAME to the desired admin username
# Set ADMIN_PASSWORD_HASH to the bcrypt hash of your admin password
# Generate hash: node scripts/generate-admin-hash.js yourpassword
ADMIN_USERNAME=arcadmin
ADMIN_PASSWORD_HASH=
